# ========================================
# Ícaro — Configuración de Entorno
# Copiar a .env y completar valores reales
# ========================================

# --- IA (requerido para Gemini y RAG) ---
GEMINI_API_KEY=
NVIDIA_API_KEY=
API_KEY_OPENAI=

# --- Modelo local (Ollama) ---
MODELO_OLLAMA=qwen2.5:1.5b

# --- Perfil ---
USER_NAME=Jesús
OBSIDIAN_VAULT_PATH=
GITHUB_TOKEN=

# --- Rendimiento ---
AI_WARMUP=false
AI_ENABLE_RAG=true
AI_ENABLE_MCP=true
AI_MAX_MCP_WORKERS=2

# --- Entorno (legacy / init_security) ---
ENVIRONMENT=development
DEBUG=False
LOG_LEVEL=INFO
# Opcional: fragmento del nombre del endpoint físico de entrada.
# Ejemplo: ICARO_AUDIO_DEVICE=Varios micrófonos
ICARO_AUDIO_DEVICE=
SECRET_KEY=change-me-in-production
JWT_SECRET=change-me-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRATION=3600

# --- Base de datos (opcional, no usada por el asistente de voz) ---
DB_HOST=localhost
DB_PORT=5432
DB_NAME=asistente_ia
DB_USER=
DB_PASSWORD=
